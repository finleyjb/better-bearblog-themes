{
  "name": "better-themes",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm run '/^build:.*/'",
    "build:default": "postcss themes/default/*.css -d dist/themes/default/ --no-map",
    "build:prod:default": "postcss --env production themes/default/*.css -d dist/themes/default/prod --no-map"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.3.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "cssnano": "^8.0.1",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-load-config": "^6.0.1",
    "postcss-preset-env": "^11.3.0",
    "postcss-safe-parser": "^7.0.1"
  },
  "browserslist": [
    "baseline widely available with downstream and not dead"
  ]
}
